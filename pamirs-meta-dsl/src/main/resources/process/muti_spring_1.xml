<process name="muti_spring" version="1">
  <event name="park">
    <spring-bean beanId="mockClazz" method="shot" args="a, b" result="r"/>
    <spring-bean beanId="mockClazz" method="shot" args="a, b" result="r"/>
    <spring-bean beanId="mockClazz" method="shot" args="a, b" result="r"/>
  </event>
  <event name="repair" triggers="park" rules="don't to that">
