<view widget="form" type="FORM" name="EmailSenderSourceForm" title="邮件服务器" model="pamirs.message.EmailSenderSource">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
        <action name="create" invisible="activeRecord.id" model="pamirs.message.EmailSenderSource" goBack="true" validateForm="true" tag="contextFreeAction"/>
        <action name="update" invisible="!activeRecord.id" model="pamirs.message.EmailSenderSource" goBack="true" validateForm="true" tag="contextFreeAction"/>
    </template>
    <template slot="fields">
        <pack widget="group" title="基础信息" cols="2">
            <field name="id" invisible="true" model="pamirs.message.EmailSenderSource" data="id"/>
            <field span="1" name="name" widget="Input" model="pamirs.message.EmailSenderSource" data="name" label="名称"
                   required="true"/>
            <field span="1" name="smtpUser" widget="Input" model="pamirs.message.EmailSenderSource" data="smtpUser"
                   label="SMTP用户名" required="true"/>
            <field span="1" name="smtpSecurity" widget="Select" model="pamirs.message.EmailSenderSource"
                   data="smtpSecurity" label="加密类型" required="true"/>
            <field span="1" name="smtpHost" widget="Input" model="pamirs.message.EmailSenderSource" data="smtpHost"
                   label="SMTP服务器地址" required="true"/>
            <field span="1" name="smtpPort" widget="Integer" model="pamirs.message.EmailSenderSource" data="smtpPort"
                   label="SMTP服务器端口" required="true"/>
            <field span="1" name="active" widget="Select" model="pamirs.message.EmailSenderSource" data="active"
                   label="是否启用"/>
        </pack>
    </template>
</view>