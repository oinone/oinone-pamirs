<view type="DETAIL" model="pamirs.message.SmsTemplate" name="SmsTemplateDetail" title="短信模板">
    <template slot="actions">
        <action name="$$internal_GotoListTableRouter" label="返回" type="default"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>

        <pack widget="group" title="基础信息" cols="2">
            <field data="name" label="模板名称" span="1"/>
            <field data="templateType" label="模板类型" span="1"/>
            <field data="templateCode" label="模板编码" span="1"/>
            <field data="templateContent" label="模板内容" span="1"/>
            <field data="channel" label="短信通道" span="1"/>
            <field data="status" label="审核状态" span="1"/>
            <field data="timeInterval" label="验证码有效时间（秒/s）" span="1"/>
        </pack>
    </template>
</view>