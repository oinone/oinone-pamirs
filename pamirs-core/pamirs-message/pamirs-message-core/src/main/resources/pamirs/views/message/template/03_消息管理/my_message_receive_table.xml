<view widget="table" model="pamirs.message.UnreadMessage" name="UnreadMessageTable" type="TABLE" title="消息列表">

    <template slot="rowActions">
        <action name="redirectDetailPage" label="详情" model="pamirs.message.UnreadMessage" text="详情"/>
    </template>

    <template slot="search" widget="search">
        <pack gutter="24,24" widget="row">
            <field allowClear="true" name="messageType" widget="Select" model="pamirs.message.UnreadMessage" data="messageType" label="消息类型"/>
            <field allowClear="true" name="readDone" widget="Select" model="pamirs.message.UnreadMessage" data="readDone" label="是否已读" defaultValue=""/>
        </pack>
    </template>

    <template slot="fields">
        <field name="id" invisible="true" model="pamirs.message.UnreadMessage" data="id"/>
        <field name="messageType" widget="Select" model="pamirs.message.UnreadMessage" data="messageType" label="消息类型"/>
        <field name="messageSummary" widget="Input" model="pamirs.message.UnreadMessage" data="messageSummary"
               label="消息摘要"/>
        <field name="readDone" model="pamirs.message.UnreadMessage" data="readDone" label="是否已读" required="false"/>
        <field name="createDate" model="pamirs.message.UnreadMessage" data="createDate" label="消息时间" required="false"/>
    </template>
</view>