<view widget="table" title="邮箱验证模板" name="EmailVerifyTemplateTable" type="TABLE" model="pamirs.message.EmailVerifyTemplate"
      excluded-actions="$$internal_GotoListImportDialog,$$internal_GotoListExportDialog">
    <template slot="actions">
        <action name="redirectCreatePage" label="创建" model="pamirs.message.EmailVerifyTemplate" text="创建"/>
        <action name="delete" label="删除" model="pamirs.message.EmailVerifyTemplate" text="删除"/>
    </template>
    <template slot="rowActions">
        <action name="redirectUpdatePage" label="编辑" model="pamirs.message.EmailVerifyTemplate" text="编辑"/>
        <action name="redirectDetailPage" label="详情" model="pamirs.message.EmailVerifyTemplate" text="详情"/>
    </template>
    <template slot="search" widget="search">
        <pack gutter="24,24" widget="row">
            <field allowClear="true" name="title" widget="Input" model="pamirs.message.EmailVerifyTemplate" data="title" label="邮件标题" required="false"/>
            <field allowClear="true" name="templateType" widget="Select" model="pamirs.message.EmailVerifyTemplate" data="templateType" label="邮件验证模板类型" required="true"/>
            <field allowClear="true" name="createDate" widget="DateTimePicker" model="pamirs.message.EmailVerifyTemplate" data="createDate" label="创建时间" required="false"/>
            <field allowClear="true" name="writeDate" widget="DateTimePicker" model="pamirs.message.EmailVerifyTemplate" data="writeDate" label="修改时间" required="false"/>
        </pack>
    </template>
    <template slot="fields">
        <field name="id" invisible="true" model="pamirs.message.EmailVerifyTemplate" data="id"/>
        <field name="title" widget="Input" model="pamirs.message.EmailVerifyTemplate" data="title" label="邮件标题" required="false"/>
        <field name="templateType" widget="Select" model="pamirs.message.EmailVerifyTemplate" data="templateType" label="邮件验证模板类型" required="true"/>
        <field name="timeInterval" widget="Integer" model="pamirs.message.EmailVerifyTemplate" data="timeInterval" label="验证码有效时间"/>
        <field name="createUid" widget="UserInput" model="pamirs.message.EmailVerifyTemplate" data="createUid" label="创建人" required="false"/>
        <field name="writeUid" widget="UserInput" model="pamirs.message.EmailVerifyTemplate" data="writeUid" label="修改人" required="false"/>
        <field name="createDate" widget="DateTimePicker" model="pamirs.message.EmailVerifyTemplate" data="createDate" label="创建时间" required="false"/>
        <field name="writeDate" widget="DateTimePicker" model="pamirs.message.EmailVerifyTemplate" data="writeDate" label="修改时间" required="false"/>
    </template>
</view>