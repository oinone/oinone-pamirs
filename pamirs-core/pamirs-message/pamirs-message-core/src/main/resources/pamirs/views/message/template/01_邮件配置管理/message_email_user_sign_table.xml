<view widget="table" model="pamirs.message.EmailUserSign" type="TABLE" name="邮件签名table" title="邮件签名"
      excluded-actions="$$internal_GotoListImportDialog,$$internal_GotoListExportDialog">
    <template slot="actions">
        <action name="redirectCreatePage" label="创建" model="pamirs.message.EmailUserSign" text="创建"/>
        <action name="delete" label="删除" model="pamirs.message.EmailUserSign" text="删除"/>
    </template>
    <template slot="rowActions">
        <action name="redirectUpdatePage" label="编辑" model="pamirs.message.EmailUserSign" text="编辑"/>
        <action name="redirectDetailPage" label="详情" model="pamirs.message.EmailUserSign" text="详情"/>
    </template>

    <template slot="search" widget="search">
        <pack gutter="24,24" widget="row">
            <field allowClear="true" name="name" widget="Input" model="pamirs.message.EmailUserSign" data="name" label="邮件签名名称" required="true"/>
            <field allowClear="true" name="partner" widget="Select" model="pamirs.message.EmailUserSign" data="partner" label="用户" required="false"/>
        </pack>
    </template>

    <template slot="fields">
        <field name="id" invisible="true" model="pamirs.message.EmailUserSign" data="id"/>
        <field span="1" name="name" widget="Input" model="pamirs.message.EmailUserSign" data="name" label="邮件签名名称" required="true"/>
        <field span="1" name="partner" widget="Select" model="pamirs.message.EmailUserSign" data="partner" label="用户" required="false"/>
        <field span="2" name="emailSignature" widget="Html" model="pamirs.message.EmailUserSign" data="emailSignature" label="邮件签名" required="true"/>
    </template>
</view>