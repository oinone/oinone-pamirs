<view type="FORM" title="创建用户" name="create_user_view" widget="form" model="user.PamirsUser">
    <template slot="actions">
        <action name="$$internal_GotoListTableRouter" label="返回" type="default"/>
        <action name="create" invisible="activeRecord.id" goBack="true" validateForm="true"/>
        <action name="update" invisible="!activeRecord.id" goBack="true" validateForm="true"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <pack widget="group" title="基础信息" cols="2">
            <field data="name" label="名称" required="true" span="1"/>
            <field data="nickname" label="昵称" span="1" invisible="true"/>
            <field data="login" label="登录账号" required="true" readonly="activeRecord.id" span="1"/>
            <field data="phone" label="登录手机" span="1"/>
            <field data="email" label="登录邮箱" span="1"/>
            <field data="initialPassword" required="true" label="初始密码" span="1"/>
            <field data="active" label="是否激活账号" span="1"/>
            <field span="2" name="roles" data="roles" label="绑定角色" optionLabel="activeRecord.name" widget="Transfer"/>
        </pack>
        <pack widget="group" title="个人信息" cols="2">
            <field data="realname" label="姓名" span="1"/>
            <field data="gender" label="性别" span="1"/>
            <field data="idCard" label="身份证号码" span="1"/>
            <field data="birthday" label="生日" span="1" endDate="NOW()" widget="DatePicker" endDateOffsetUnit="day" dateFormat="HYPHEN" startDateOffsetUnit="day"/>
            <field data="regDate" label="注册日期" span="1" invisible="true"/>
            <field data="contactPhone" label="联系电话" span="1"/>
            <field data="contactEmail" label="联系邮箱" span="1"/>
        </pack>

        <pack widget="group" title="其他信息" cols="2">
            <field span="1" name="regDate" data="regDate" label="注册日期" readonly="true"/>
        </pack>
