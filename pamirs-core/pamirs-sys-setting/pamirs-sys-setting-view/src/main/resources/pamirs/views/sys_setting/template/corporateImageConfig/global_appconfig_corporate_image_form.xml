<view type="FORM" widget="form" name="GlobalAppConfigProxy_CorporateImage_Form" title="企业形象配置"
      model="sysSetting.GlobalAppConfigProxy">
    <template slot="actions">
        <action name="saveCorporateImageSetting" label="发布"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <pack title="企业信息">
            <field data="partnerName" invisible="true"/>
            <field data="officialWebsite" invisible="true"/>
            <field data="slogan" invisible="true"/>
        </pack>
        <pack title="LOGO设置">
            <pack title="业务应用导航栏logo">
                <field data="logo" invisible="true" hint="请上传jpg、png格式的图片，文件大小不超过5MB"/>
            </pack>
            <pack title="浏览器logo">
                <field data="smallLogo" invisible="true" hint="请上传jpg、png格式的图片，文件大小不超过5MB"/>
            </pack>
        </pack>
    </template>
</view>