<view type="FORM" widget="form" name="GlobalAppConfigProxy_Login_Form" title="登录页配置"
      model="sysSetting.GlobalAppConfigProxy">
    <template slot="actions">
        <action name="saveLoginSetting" label="发布"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <pack title="页面布局">
            <field data="loginLayoutType" invisible="true"/>
        </pack>
        <pack title="页面背景">
            <field data="loginBackground"
                   hint="请上传jpg、png格式的图片或mp4、mov、avi格式视频。尺寸建议为1200*1080px，文件大小不超过50MB"
                   invisible="true"/>

        </pack>
        <pack title="登录页logo">
            <field data="loginPageLogo" hint="请上传jpg、png格式的图片，文件大小不超过5MB" invisible="true"/>
        </pack>
    </template>
</view>