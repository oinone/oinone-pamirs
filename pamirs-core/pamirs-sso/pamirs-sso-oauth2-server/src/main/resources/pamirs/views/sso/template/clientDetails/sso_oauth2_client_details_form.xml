<view model="sso.SsoOauth2ClientDetails" type="form" name="ssoOauth2ClientDetailsForm">
    <template slot="actionBar">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
        <action name="update" disabled="IS_NULL(activeRecord.id)" goBack="true"/>
    </template>
    <template slot="form">
        <pack title="基础信息" widget="group">
            <field colSpan="HALF" data="clientId" disabled="false" invisible="false" readonly="true" required="false" widget="Input"/>
            <field colSpan="HALF" data="clientSecret" disabled="false" invisible="false" readonly="true" required="false" widget="TextArea"/>
            <field colSpan="HALF" data="enabled" disabled="false" invisible="false" readonly="false" required="false" widget="Switch"/>
            <field colSpan="HALF" data="callbackUrl" disabled="false" invisible="false" readonly="false" required="false" widget="Input"/>
            <field colSpan="HALF" data="expiresIn" disabled="false" invisible="false" readonly="false" required="false" widget="Integer"/>
            <field colSpan="HALF" data="refreshTokenExpiresIn" disabled="false" invisible="false" readonly="false" required="false" widget="Integer"/>
            <field colSpan="HALF" data="codeExpiresIn" disabled="false" invisible="false" readonly="false" required="false" widget="Integer"/>
            <field colSpan="HALF" data="homepageUrl" disabled="false" invisible="false" readonly="false" required="false" widget="Input"/>
            <field colSpan="HALF" data="logoutUrl" disabled="false" invisible="false" readonly="false" required="false" widget="Input"/>
            <field colSpan="HALF" data="privateKey" disabled="false" invisible="false" readonly="true" required="false" widget="TextArea"/>
            <field colSpan="HALF" data="publicKey" disabled="false" invisible="false" readonly="true" required="false" widget="TextArea"/>
            <field colSpan="HALF" data="cacheTokenExpirationTime" disabled="false" invisible="false" readonly="false" required="false" widget="Integer"/>
        </pack>
        <field data="id" invisible="true"/>
    </template>
</view>
