<view name="formView" type="FORM" cols="2" model="sso.SsoClient">
    <template slot="actions" autoFill="true"/>
    <template slot="fields">
        <pack widget="group" title="基础信息">
            <field span="1" invisible="true" data="id" label="ID" readonly="true"/>
            <field span="1" data="name" label="客户端应用名"/>
            <field span="1" data="clientId" label="应用标识(client_id)" readonly="true"/>
            <field span="1" data="clientSecret" label="应用密钥(client_secret)" readonly="true"/>
            <field span="1" widget="Switch" data="enabled" label="是否开启SSO"/>
            <field span="1" data="authType" label="认证类型">
                <options>
                    <option name="OAUTH2" displayName="OAuth2" value="OAUTH2" state="ACTIVE"/>
                    <option name="CAS" displayName="CAS" value="CAS" state="ACTIVE"/>
                    <option name="SAML" displayName="SAML" value="SAML" state="ACTIVE"/>
                    <option name="AD" displayName="AD" value="AD" state="ACTIVE"/>
                    <option name="KERBEROS" displayName="Kerberos" value="KERBEROS" state="ACTIVE"/>
                </options>
            </field>
            <field span="1" data="expiresIn" label="access_token超时时间"/>
            <field span="1" data="refreshTokenExpiresIn" label="refresh_Token超时时间"/>
            <field span="1" data="codeExpiresIn" label="auth_code超时时间"/>
            <field span="1" data="homepageUrl" label="跳转首页"/>
            <field span="1" data="logoutUrl" label="设置退出地址"/>
            <field span="1" data="privateKey" label="密钥" readonly="true"/>
            <field span="1" data="publicKey" label="公钥" readonly="true"/>
            <field span="1" data="cacheTokenExpirationTime" label="缓存上一次对AccessToken失效时间"/>
            <field data="remark" label="应用备注"/>
            <field span="1" invisible="true" data="createDate" label="创建时间" readonly="true"/>
            <field span="1" invisible="true" data="writeDate" label="更新时间" readonly="true"/>
            <field span="1" data="createUid" label="创建人ID"/>
            <field span="1" data="writeUid" label="更新人ID"/>
        </pack>
    </template>
</view>