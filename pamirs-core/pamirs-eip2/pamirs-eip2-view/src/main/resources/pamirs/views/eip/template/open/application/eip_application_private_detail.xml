<view type="DETAIL" widget="detail" title="查看密钥" model="pamirs.eip.proxy.EipApplicationProxy" name="EipApplicationProxyDetail">
    <template slot="actions">
        <action fun="$$internal_GotoListTableRouter" label="返回" actionType="CLIENT" type="default"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>

        <field data="appKey" label="API Key"/>
        <field data="appSecret" label="API Secret" widget="StringWithCopy"/>
        <field data="publicKey" label="数据传输加密密钥" widget="StringWithCopy"/>
    </template>
</view>
