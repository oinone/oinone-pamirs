<view type="FORM" widget="form" title="授权调整" model="pamirs.eip.proxy.EipApplicationProxy"
      name="集成应用接口授权form">
    <template slot="actions">
        <action fun="$$internal_GotoListTableRouter" label="返回" actionType="CLIENT" type="default"/>
        <action name="update" label="保存" goBack="true" validateForm="true"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>

        <pack widget="group" title="基础信息" cols="1">
            <field data="code" label="应用编码" readonly="true"/>
            <field data="name" label="应用名称" readonly="true"/>
            <field data="appKey" label="API Key" readonly="true"/>
            <field data="requestDecryptFunc" label="请求解密处理函数" readonly="true"/>
            <field data="responseEncryptionFunc" label="响应加密处理函数" readonly="true"/>
            <field data="description" label="应用描述" readonly="true"/>
        </pack>

        <pack widget="group" title="授权API范围" cols="1">
            <field data="openInterfaceList" widget="WorkScopeWidget"/>
        </pack>

        <pack widget="group" title="IP白名单配置" cols="1">
            <field data="ipWhiteRespHttpCode" label="状态码" readonly="false" placeholder="被IP白名单规则限制时的响应状态码，默认403"/>
            <field data="ipWhiteHttpResult" label="响应结果" readonly="false" placeholder="被IP白名单规则限制时的响应结果"/>
            <field data="ipWhiteList" label="IP白名单" readonly="false" placeholder="请输入IP 或 IP网段"
                   patternType="CUSTOM" rows="10"
                   pattern="/^(?:(?:\d{1,3}\.){3}\d{1,3}(?:\/(?:[1-2][0-9]|3[0-2]|[0-9]))?)(?:,(?:\d{1,3}\.){3}\d{1,3}(?:\/(?:[1-2][0-9]|3[0-2]|[0-9]))?){0,499}$/"/>
            <element borderMode="NONE" disabled="false" invisible="false" readonly="false"
                     required="false" widget="paragraph"
                     content="&lt;p&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0.25);&quot;&gt;多个 IP 用英文逗号分隔，无空格。&lt;/span&gt;&lt;/p&gt;
                              &lt;p&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0.25);&quot;&gt;设置为 0.0.0.0/0 或留空表示 允许全部地址。&lt;/span&gt;&lt;/p&gt;
                              &lt;p&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0.25);&quot;&gt;支持 IP 段，如 10.10.10.0/24。&lt;/span&gt;&lt;/p&gt;
                              &lt;p&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0.25);&quot;&gt;最大支持配置 500 条规则。&lt;/span&gt;&lt;/p&gt;
                              &lt;p&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0.25);&quot;&gt;暂不支持 IPv6 地址。&lt;/span&gt;&lt;/p&gt;"
            />
        </pack>
    </template>
</view>