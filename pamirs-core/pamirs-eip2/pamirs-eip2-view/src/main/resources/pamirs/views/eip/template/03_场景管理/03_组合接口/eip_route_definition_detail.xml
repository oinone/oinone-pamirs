<view type="DETAIL" widget="detail" model="pamirs.eip.EipRouteDefinition" name="EipRouteDefinitionDetail">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
    </template>
    <template slot="fields">
        <field name="id" invisible="true" model="pamirs.eip.EipRouteDefinition" data="id"/>
        <pack widget="group" title="基础信息" cols="2">
            <field span="1" name="name" widget="Input" model="pamirs.eip.EipRouteDefinition" data="name" label="名称"/>
            <field span="1" name="interfaceName" widget="Input" model="pamirs.eip.EipRouteDefinition" data="interfaceName" label="技术名称"/>
            <field span="1" name="tenant" widget="Input" model="pamirs.eip.EipRouteDefinition" data="tenant" label="租户"/>
            <field span="1" name="dataStatus" widget="Select" model="pamirs.eip.EipRouteDefinition" data="dataStatus" label="状态"/>
        </pack>
    </template>
</view>