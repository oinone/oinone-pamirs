    },
    "EIP_FUNCTION_WITH_RESULT": {
      "displayName": "Eip function - has return",
      "help": "Call the function with the specified eip parameter, the return result is OpenEipResult, and it is automatically placed into finalResultKey"
    },
    "MODEL_FUNCTION": {
      "displayName": "model function",
      "help": "Call the model function, the input parameter must be a single-parameter model, convert the request input parameter to the input parameter, the return result is automatically packaged into a unified format for the open interface, and placed into finalResultKey"
    },
    "FUNCTION": {
      "displayName": "Business function",
      "help": "Call any function, obtain parameters from the request context based on the function's input parameters, automatically wrap the return result into a unified open interface format, and put it into finalResultKey"
    }
