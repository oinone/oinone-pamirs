    <artifactId>pamirs-eip2</artifactId>
    <name>pamirs-eip2</name>
    <packaging>pom</packaging>

    <properties>
        <camel.version>3.4.0</camel.version>
        <resilience4j.version>1.7.1</resilience4j.version>
    </properties>

    <modules>
        <module>pamirs-eip2-api</module>
        <module>pamirs-eip2-core</module>
        <module>pamirs-eip2-view</module>
        <module>pamirs-eip2-jdbc</module>
        <module>pamirs-eip2-designer</module>
