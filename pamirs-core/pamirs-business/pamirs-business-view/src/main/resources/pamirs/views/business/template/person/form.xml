<view widget="form" model="business.PamirsPerson" type="FORM" title="个人" name="个人form">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
        <action name="create" invisible="activeRecord.id &gt; 0" model="business.PamirsPerson" goBack="true" validateForm="true" tag="contextFreeAction"/>
        <action name="update" invisible="!(activeRecord.id &gt; 0)" model="business.PamirsPerson" goBack="true" validateForm="true" tag="contextFreeAction"/>
    </template>
    <template slot="fields">
        <field name="id" invisible="true" model="business.PamirsPerson" data="id"/>
        <pack widget="group" title="基础信息" cols="2">
            <field span="1" name="code" model="business.PamirsPerson" data="code" label="个人编码" hint="未填时将自动生成" required="false" readonly="activeRecord.id"/>
            <field span="1" name="name" model="business.PamirsPerson" data="name" label="个人名称"/>
            <field span="1" invisible="!activeRecord.id" name="dataStatus" model="business.PamirsPerson" data="dataStatus" label="数据状态" readonly="true"/>
        </pack>
    </template>
</view>