<view type="FORM" title="员工" name="员工form" widget="form" model="business.PamirsEmployee">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
        <action name="create" invisible="activeRecord.id &gt; 0"  goBack="true" validateForm="true" tag="contextFreeAction"/>
        <action name="update" invisible="!(activeRecord.id &gt; 0)"  goBack="true" validateForm="true" tag="contextFreeAction"/>
    </template>
    <template slot="fields">
        <field name="id" invisible="true" data="id"/>
        <pack widget="group" title="基础信息" cols="2">
            <field span="1" name="code" data="code" label="员工编码" hint="未填时将自动生成" required="false" readonly="activeRecord.id"/>
            <field span="1" name="name" data="name" label="员工名称"/>
            <field span="1" name="phone" data="phone" label="员工手机号"/>
            <field name="company" data="company" label="所属公司" required="true"/>
            <field name="department" data="department" label="所属主部门" domain="companyCode == ${activeRecord.company.code}" disabled="!activeRecord.company.code" />
            <field name="dataStatus" data="dataStatus" label="数据状态" readonly="true" span="1" invisible="!activeRecord.id" />
        </pack>
        <pack widget="group" title="用户信息" cols="2">
            <field span="1" name="bindingMode" data="bindingMode" clearFields="login,userEmail,initialPassword,defaultBindingUser" defaultValue="BINDING_EXISTING" label="用户绑定方式" placeholder="用户绑定方式" widget="Select">
                <options>
                    <option displayName="创建并绑定用户" invisible="false" label="创建并绑定用户" name="CREATE_BINDING"/>
                    <option displayName="绑定已有用户" invisible="false" label="绑定已有用户" name="BINDING_EXISTING"/>
                </options>
            </field>
            <field span="1" name="login" data="login" invisible="rootRecord.bindingMode == 'BINDING_EXISTING'" label="登录账号" placeholder="登录账号" required="true" />
            <field span="1" name="userEmail" data="userEmail" invisible="rootRecord.bindingMode == 'BINDING_EXISTING'" label="邮箱地址" placeholder="邮箱地址" />
            <field span="1" name="initialPassword" data="initialPassword" invisible="rootRecord.bindingMode == 'BINDING_EXISTING'" label="初始密码" placeholder="初始密码" required="true" />
            <field span="1" name="defaultBindingUser" data="defaultBindingUser" invisible="rootRecord.bindingMode == 'CREATE_BINDING'" label="绑定用户" optionFields="name,login,code,id" optionLabel="activeRecord.name" placeholder="绑定用户" required="true" searchFields="name,login" widget="Select"/>
        </pack>
        <pack widget="group" title="所属部门列表">
            <field name="departmentList" widget="Table" data="departmentList" label="false" submitType="all">
                <view widget="table" model="business.PamirsDepartment">
                    <template slot="actions">
                        <action name="internalGotoM2MListDialogFromPamirsEmployeeFromBusiness" label="添加" actionType="VIEW" model="business.PamirsDepartment" domain="companyCode == ${rootRecord.company.code}" disabled="!rootRecord.company.code" viewType="TABLE" resViewName="dialogTableView" tag="contextFreeAction"/>
                        <action name="$$internal_DeleteOne" label="删除" actionType="CLIENT" model="business.PamirsDepartment" contextType="SINGLE_AND_BATCH" fun="$$internal_DeleteOne" tag="contextFreeAction"/>
                    </template>
                    <template slot="fields">
                        <field name="id" invisible="true" model="business.PamirsDepartment" data="id"/>
                        <field name="code" model="business.PamirsDepartment" data="code" label="部门编码"/>
                        <field name="name" model="business.PamirsDepartment" data="name" label="部门名称"/>
                        <field name="departmentType" invisible="true" model="business.PamirsDepartment" data="departmentType" label="部门类型"/>
                        <field name="parent" model="business.PamirsDepartment" data="parent" label="上级部门"/>
                        <field name="parentCode" model="business.PamirsDepartment" data="parentCode" label="上级部门编码"/>
                    </template>
                </view>
            </field>
        </pack>
        <pack widget="group" title="所属岗位列表">
            <field name="positions" widget="Table" data="positions" label="false" submitType="all">
                <view widget="table" model="business.PamirsPosition">
                    <template slot="actions">
                        <action name="internalGotoM2MListDialogFromPamirsEmployeeFromBusiness" label="添加" actionType="VIEW" model="business.PamirsPosition" domain="companyCode == ${rootRecord.company.code}" disabled="!rootRecord.company.code" viewType="TABLE" resViewName="dialogTableView" tag="contextFreeAction"/>
                        <action name="$$internal_DeleteOne" label="删除" actionType="CLIENT" model="business.PamirsPosition" contextType="SINGLE_AND_BATCH" fun="$$internal_DeleteOne" tag="contextFreeAction"/>
                    </template>
                    <template slot="fields">
                        <field name="id" invisible="true" model="business.PamirsPosition" data="id"/>
                        <field name="code" model="business.PamirsPosition" data="code" label="岗位编码"/>
                        <field name="name" model="business.PamirsPosition" data="name" label="岗位名称"/>
                        <field name="parent" model="business.PamirsPosition" data="parent" label="所属岗位"/>
                        <field name="parentCode" model="business.PamirsPosition" data="parentCode" label="所属岗位编码"/>
                    </template>
                </view>
            </field>
        </pack>
    </template>
</view>