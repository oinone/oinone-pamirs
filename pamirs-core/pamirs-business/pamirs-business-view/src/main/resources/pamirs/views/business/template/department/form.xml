<view type="FORM" title="部门" name="部门form" widget="form" model="business.PamirsDepartment">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
        <action name="create" invisible="activeRecord.id &gt; 0" model="business.PamirsDepartment" goBack="true" validateForm="true" tag="contextFreeAction"/>
        <action name="update" invisible="!(activeRecord.id &gt; 0)" model="business.PamirsDepartment" goBack="true" validateForm="true" tag="contextFreeAction"/>
    </template>
    <template slot="fields">
        <field name="id" invisible="true" model="business.PamirsDepartment" data="id"/>
        <pack widget="group" title="基础信息" cols="2">
            <field span="1" name="code" model="business.PamirsDepartment" data="code" label="部门编码" hint="未填时将自动生成" required="false" readonly="activeRecord.id"/>
            <field span="1" name="name" model="business.PamirsDepartment" data="name" label="部门名称" required="true"/>
            <field span="1" name="company" model="business.PamirsDepartment" data="company" label="所属公司" required="true" clearFields="employeeRelList"/>
            <field span="1" name="parent" model="business.PamirsDepartment" data="parent" label="上级部门" domain="companyCode == '${activeRecord.company.code}' and code != '${activeRecord.code}'"/>
            <field span="1" name="departmentType" model="business.PamirsDepartment" data="departmentType" label="部门类型"/>
            <field span="2" name="description" model="business.PamirsDepartment" data="description" label="备注"/>
            <field span="1" invisible="!activeRecord.id" name="dataStatus" model="business.PamirsDepartment" data="dataStatus" label="数据状态"/>
        </pack>
        <pack widget="tabs">
            <pack widget="tab" title="岗位列表">
                <field name="positionList" widget="Table" model="business.PamirsDepartment" data="positionList" label="false">
                    <view widget="table" model="business.PamirsPosition">
                        <template slot="actions">
                            <action name="internalGotoO2MCreateDialogFromPamirsDepartmentFromBusiness" label="添加" disabled="!rootRecord.company.code" context-companyCode="rootRecord.company.code" actionType="VIEW" model="business.PamirsPosition" viewType="FORM" xresViewName="dialogFormView" tag="contextFreeAction">
                                <template slot="default">
                                    <view name="dialogFormViewFromPamirsDepartment" type="FORM" cols="2" model="business.PamirsPosition">
                                        <template slot="fields">
                                            <pack widget="group" title="基础信息" border="false">
                                                <field span="1" invisible="true" priority="5" data="id" label="ID" readonly="true"/>
                                                <field span="1" priority="90" data="code" label="编码" required="false" hint="未填时将自动生成"/>
                                                <field span="1" priority="103" data="positionType" label="岗位类型"/>
                                                <field span="1" priority="104" data="name" label="岗位名称"/>
                                                <field span="1" priority="109" data="companyCode" label="所属公司编码" invisible="true"/>
                                                <field span="1" widget="Select" priority="110" data="parent" label="直属岗位" domain="companyCode == ${activeRecord.companyCode}"/>
                                                <field span="1" priority="111" data="dataStatus" label="数据状态"/>
                                            </pack>
                                        </template>
                                    </view>
                                </template>
                            </action>
                            <action name="$$internal_DeleteOne" label="删除" actionType="CLIENT" model="business.PamirsPosition" contextType="SINGLE_AND_BATCH" fun="$$internal_DeleteOne" tag="contextFreeAction"/>
                        </template>
                        <template slot="fields">
                            <field name="id" invisible="true" model="business.PamirsPosition" data="id"/>
                            <field name="code" model="business.PamirsPosition" data="code" label="岗位编码"/>
                            <field name="name" model="business.PamirsPosition" data="name" label="岗位名称"/>
                            <field data="companyCode" label="所属公司编码" invisible="true"/>
                            <field name="parent" model="business.PamirsPosition" data="parent" label="直属岗位"/>
                            <field data="dataStatus" label="数据状态"/>
                        </template>
                    </view>
                </field>
            </pack>
            <pack title="员工列表" widget="tab">
                <field data="employeeRelList" widget="Table" name="employeeRelList" model="business.PamirsDepartment" labelInvisible="true"
                       constructFun="constructEmployeeRel" constructSubmitType="CUSTOM" submitFields="id,employeeRelList">
                    <view model="business.DepartmentRelEmployeeProxy" type="table">
                        <template slot="actionBar">
                            <action invisible="false" label="添加" disabled="!rootRecord.company.code" name="LoadAddEmployeeListByDept">
                                <template slot="default">
                                    <view model="business.DepartmentRelEmployeeProxy" type="table">
                                        <template slot="search">
                                            <field data="employeeCode" label="员工编码"/>
                                            <field data="employeeName" label="员工名称"/>
                                        </template>
                                        <template slot="actionBar"/>
                                        <template slot="table" filter="companyCode==${rootRecord.company.code} and employeeId=out=(${LIST_FIELD_VALUES(rootRecord.employeeRelList, business.PamirsDepartment, employeeId)})">
                                            <field data="employeeId" label="员工id" invisible="true"/>
                                            <field data="employeeCode" label="员工编码"/>
                                            <field data="employeeName" label="员工名称"/>
                                            <field data="employeeDepartment" label="所属主部门"/>
                                            <field data="employeeDefaultBindingUser" label="绑定用户"/>
                                            <field data="employeeType" invisible="true"/>
                                            <field data="departmentCode" invisible="true"/>
                                            <field data="departmentType" invisible="true"/>
                                            <template slot="rowActions"/>
                                        </template>
                                        <template slot="header"/>
                                        <template slot="footer">
                                            <action name="$$internal_DialogSubmit" label="确定"/>
                                            <action name="$$internal_GotoListTableRouter" label="取消"/>
                                        </template>
                                    </view>
                                </template>
                            </action>
                            <action name="$$internal_DeleteOne"/>
                        </template>
                        <template slot="table">
                            <field data="employeeId" label="员工id" invisible="true"/>
                            <field data="employeeCode" label="员工编码"/>
                            <field data="employeeName" label="员工名称"/>
                            <field data="employeeDepartment" label="所属主部门"/>
                            <field data="employeeDefaultBindingUser" label="绑定用户"/>
                            <field data="supervisor" label="是否为部门主管" widget="Switch" editable="true"/>
                            <field data="departmentCode" invisible="true"/>
                            <field data="departmentType" invisible="true"/>
                            <field data="employeeType" invisible="true"/>
                            <template slot="rowActions"/>
                        </template>
                    </view>
                </field>
            </pack>
        </pack>
    </template>
</view>