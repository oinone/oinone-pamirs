<view type="FORM" model="business.PamirsDepartment" name="部门form" title="部门">
    <template slot="actions">
        <action name="$$internal_GotoListTableRouter" label="返回" type="default"/>
        <action name="create" invisible="activeRecord.id" goBack="true" validateForm="true"/>
        <action name="update" invisible="!activeRecord.id" goBack="true" validateForm="true"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <pack title="基础信息" cols="2">
            <field data="code" label="部门编码" hint="未填时将自动生成" required="false" readonly="activeRecord.id" span="1"/>
            <field data="name" label="部门名称" required="true" span="1"/>
            <field data="company" label="所属公司" required="true" clearFields="employeeList" span="1"/>
            <field data="parent" label="上级部门" domain="companyCode == '${activeRecord.company.code}' and code != '${activeRecord.code}'" span="1"/>
            <field data="departmentType" label="部门类型" span="1"/>
            <field data="description" label="备注" span="2"/>
            <field data="dataStatus" label="数据状态" invisible="!activeRecord.id" span="1"/>
        </pack>
        <pack widget="tabs">
            <pack widget="tab" title="岗位列表">
                <field data="positionList" widget="Table" label="false">
                    <view type="table">
                        <template slot="actions">
                            <action name="internalGotoO2MCreateDialogFromPamirsDepartmentFromBusiness" label="添加" disabled="!rootRecord.company.code" context-companyCode="rootRecord.company.code">
                                <template slot="default">
                                    <view type="form" cols="2">
                                        <template slot="fields">
                                            <pack widget="group" title="基础信息" border="false">
                                                <field data="id" invisible="true"/>
                                                <field data="parentCode" compute="activeRecord.parent.code" invisible="true"/>

                                                <field data="code" label="编码" hint="未填时将自动生成" required="false" span="1"/>
                                                <field data="positionType" label="岗位类型" span="1"/>
                                                <field data="name" label="岗位名称" span="1"/>
                                                <field data="companyCode" label="所属公司编码" invisible="true" span="1"/>
                                                <field data="parent" label="直属岗位" domain="companyCode == ${activeRecord.companyCode}" span="1"/>
                                                <field data="dataStatus" label="数据状态" span="1"/>
                                            </pack>
                                        </template>
                                    </view>
                                </template>
                            </action>
                            <action name="$$internal_DeleteOne" label="删除"/>
                        </template>
                        <template slot="fields">
                            <field data="id" invisible="true"/>
                            <field data="parentCode" compute="activeRecord.parent.code" invisible="true"/>

                            <field data="code" label="岗位编码"/>
                            <field data="name" label="岗位名称"/>
                            <field data="companyCode" label="所属公司编码" invisible="true"/>
                            <field data="parent" label="直属岗位"/>
                            <field data="dataStatus" label="数据状态"/>
                        </template>
                    </view>
                </field>
            </pack>
            <pack title="员工列表" widget="tab">
                <field data="employeeList" widget="Table" constructFun="constructEmployeeList" constructSubmitType="CUSTOM" label="false" submitType="ALL">
                    <view type="table">
                        <template slot="actionBar">
                            <action label="添加" disabled="!rootRecord.company.code" name="internalGotoM2MListDialogFromPamirsDepartmentFromBusiness">
                                <template slot="default">
                                    <view type="table">
                                        <template slot="search">
                                            <field data="code" label="员工编码"/>
                                            <field data="name" label="员工名称"/>
                                        </template>
                                        <template slot="actionBar"/>
                                        <template slot="table" filter="companyCode==${rootRecord.company.code} and id=out=(${LIST_IDS(rootRecord.employeeList)})">
                                            <field data="id" invisible="true"/>
                                            <field data="employeeType" invisible="true"/>

                                            <field data="code" label="员工编码"/>
                                            <field data="name" label="员工名称"/>
                                            <field data="department" label="所属主部门"/>
                                            <field data="defaultBindingUser" label="绑定用户"/>
                                            <template slot="rowActions"/>
                                        </template>
                                        <template slot="header"/>
                                        <template slot="footer">
                                            <action name="$$internal_DialogSubmit" label="确定"/>
                                            <action name="$$internal_GotoListTableRouter" label="取消"/>
                                        </template>
                                    </view>
                                </template>
                            </action>
                            <action name="$$internal_DeleteOne"/>
                        </template>
                        <template slot="table">
                            <field data="id" invisible="true"/>
                            <field data="employeeType" invisible="true"/>
                            <field data="code" label="员工编码"/>
                            <field data="name" label="员工名称"/>
                            <field data="department" label="所属主部门"/>
                            <field data="defaultBindingUser" label="绑定用户"/>
                            <field data="supervisor" label="是否为部门主管" widget="Switch" editable="true"/>
                            <template slot="rowActions"/>
                        </template>
                    </view>
                </field>
            </pack>
        </pack>
    </template>
</view>