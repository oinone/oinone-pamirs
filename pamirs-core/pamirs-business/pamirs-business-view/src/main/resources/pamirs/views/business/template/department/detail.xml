<view type="DETAIL" title="部门" name="部门detail" widget="detail" model="business.PamirsDepartment">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
    </template>
    <template slot="fields">
        <field name="id" invisible="true" model="business.PamirsDepartment" data="id"/>
        <pack widget="group" title="基础信息" cols="2">
            <field span="1" name="code" model="business.PamirsDepartment" data="code" label="部门编码" hint="未填时将自动生成"/>
            <field span="1" name="name" model="business.PamirsDepartment" data="name" label="部门名称"/>
            <field span="1" name="company" model="business.PamirsDepartment" data="company" label="所属公司"/>
            <field span="1" name="parent" model="business.PamirsDepartment" data="parent" label="上级部门"/>
            <field span="1" name="departmentType" model="business.PamirsDepartment" data="departmentType" label="部门类型"/>
            <field span="2" name="description" model="business.PamirsDepartment" data="description" label="备注"/>
            <field span="1" name="dataStatus" model="business.PamirsDepartment" data="dataStatus" label="数据状态"/>
        </pack>
        <pack widget="tabs">
            <pack widget="table" title="岗位列表">
                <field name="positionList" widget="Table" model="business.PamirsDepartment" data="positionList" label="false">
                    <view widget="table" model="business.PamirsPosition" excluded-actions="$$internal_GotoO2MCreateDialog,$$internal_GotoO2MEditDialog,$$internal_DeleteOne">
                        <template slot="fields">
                            <field name="id" invisible="true" model="business.PamirsPosition" data="id"/>
                            <field name="code" model="business.PamirsPosition" data="code" label="岗位编码"/>
                            <field name="name" model="business.PamirsPosition" data="name" label="岗位名称"/>
                            <field name="parent" model="business.PamirsPosition" data="parent" label="直属岗位"/>
                            <field name="parentCode" model="business.PamirsPosition" data="parentCode" label="直属岗位编码"/>
                        </template>
                    </view>
                </field>
            </pack>
            <pack title="员工列表" widget="tab">
                <field data="employeeList" widget="Table" labelInvisible="true" load="false">
                    <view type="table">
                        <template slot="table">
                            <field data="id" label="员工id" invisible="true"/>
                            <field data="code" label="员工编码"/>
                            <field data="name" label="员工名称"/>
                            <field data="department" label="所属主部门"/>
                            <field data="defaultBindingUser" label="绑定用户"/>
                            <field data="supervisor" label="是否为部门主管"/>
                        </template>
                    </view>
                </field>
            </pack>
        </pack>
    </template>
</view>