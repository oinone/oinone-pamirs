<view type="FORM" model="auth.AuthRbacRolePermissionProxy" name="AuthRbacRolePermissionForm" title="权限配置">
    <template slot="actions">
        <action name="$$internal_GotoListTableRouter" type="default"/>
        <action name="update" goBack="true" validateForm="true"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <field data="nodesJson" invisible="true" submitType="NONE"/>
        <field data="enterpriseEdition" invisible="true" submitType="NONE"/>
        <pack widget="group" title="角色信息" cols="2">
            <field data="code" label="角色编码" hint="未填时将自动生成" readonly="activeRecord.id" span="1"/>
            <field data="name" label="角色名称" required="true" span="1"/>
            <field data="roleType" label="角色类型" span="1"/>
            <field data="description" label="角色描述" span="2"/>
        </pack>
        <pack widget="tabs">
            <pack widget="tab" title="资源访问权限" help="该权限允许访问指定的应用程序或菜单。需注意的是，若仅对二级菜单进行了权限授予，而未同时授予相应的一级菜单权限，则即便拥有二级菜单的访问权限，也无法实际进行访问。">
                <field data="resourcePermissions" widget="resource-permission" labelInvisible="true" optionFields="resourceId,path,subtype,canAccess,canManagement,canDesign"/>
            </pack>
            <pack widget="tab" title="资源管理权限" help="资源管理权限允许将管理权限进一步分配给其他用户。为确保资源管理权限的有效实施，该角色需首先具备访问‘管理中心’的权限。">
                <field data="managementPermissions" widget="management-permission" labelInvisible="true" optionFields="resourceId,path,subtype,canAccess,canManagement,canDesign"/>
            </pack>
            <pack widget="tab" title="字段权限" help="可以查看并管理该角色所有的模型及其字段权限，包括其读权限与写权限。" invisible="activeRecord.enterpriseEdition!=true">
                <pack widget="spin" cols="2" align="bottom">
                    <field data="fieldPermissionModelSelect" widget="field-permission-model-select" labelInvisible="true" span="1"
                           submitType="NONE"
                           relationUpdateType="NONE"
                           constructFun="queryFieldPermissions"
                           constructSubmitType="CUSTOM"
                           submitFields="id,fieldPermissionModelSelect">
                        <view type="table">
                            <template slot="search" invisibleSearch="true" disabledExpand="true" cols="2">
                                <field data="displayName" label="模型编码/名称" labelInvisible="true" span="1"/>
                                <field data="configured" label="仅查看已配置模型" labelInvisible="true" span="1"/>
                            </template>
                            <template slot="table" checkbox="false" selectMode="radio" domain="roleId == ${rootRecord.id}" datasource-provider="true" usingSearchCondition="false">
                                <element widget="radio-column"/>
                                <field data="id" invisible="true"/>
                                <field data="model" label="模型编码"/>
                                <field data="displayName" label="模型名称"/>
                                <field data="description" label="描述"/>
                            </template>
                        </view>
                    </field>
                    <field data="fieldPermissions" widget="field-permission" labelInvisible="true" span="1" submitType="ALL" datasource-provider="true">
                        <view type="table">
                            <template slot="table" datasource-provider="false" checkbox="false" editorTrigger="click">
                                <field data="id" invisible="true"/>
                                <field data="source" invisible="true"/>
                                <field data="model" invisible="true"/>
                                <field data="displayName"/>
                                <field data="description"/>
                                <field data="ttype"/>
                                <field data="field"/>
                                <field data="permRead" editable="true"/>
                                <field data="permWrite" editable="true"/>
                            </template>
                        </view>
                    </field>
                </pack>
            </pack>
            <pack widget="tab" title="数据权限" help="支持依据需求过滤模型字段，使得不同角色可以获得不同的数据信息。数据权限项可在「管理中心-角色与权限-数据权限项」中进行管理与维护" invisible="activeRecord.enterpriseEdition!=true">
                <field data="rowPermissions" widget="Table" label="数据权限" labelInvisible="true" submitType="ALL">
                    <view type="table">
                        <template slot="actions">
                            <action name="authRolePermissionAddRowPermission"/>
                            <action name="$$internal_DeleteOne"/>
                        </template>
                        <template slot="table" editorTrigger="click">
                            <field data="id" invisible="true"/>
                            <field data="code" invisible="true"/>
                            <field data="source" invisible="true"/>
                            <field data="model" invisible="true"/>
                            <field data="domainExpJson" invisible="true"/>
                            <field data="displayName" label="名称"/>
                            <field data="description" label="描述"/>
                            <field data="modelDefinition"/>
                            <field data="domainExp" label="过滤条件表达式"/>
                            <field data="domainExpDisplayName" label="过滤条件"/>
                            <field data="permRead" editable="true"/>
                            <field data="permWrite" invisible="true"/>
                            <field data="permDelete" invisible="true"/>
                            <field data="active" invisible="true"/>
                            <template slot="rowActions">
                                <action name="$$internal_DeleteOne"/>
                            </template>
                        </template>
                    </view>
                </field>
            </pack>
            <!--<pack widget="tab" title="自定义资源权限">-->
            <!--    <field data="customResourcePermissions" widget="Table" labelInvisible="true" relationUpdateType="diff">-->
            <!--        <view type="table">-->
            <!--            <template slot="fields">-->
            <!--                <field data="id" invisible="true"/>-->
            <!--                <field data="source" invisible="true"/>-->
            <!--                <field data="displayName"/>-->
            <!--                <field data="type"/>-->
            <!--                <field data="subtype"/>-->
            <!--                <field data="canAccess"/>-->
            <!--                <field data="canManagement"/>-->
            <!--            </template>-->
            <!--        </view>-->
            <!--    </field>-->
            <!--</pack>-->
        </pack>
    </template>
</view>
