<view type="TABLE" model="auth.AuthGroupResourcePermissionProxy" name="AuthGroupResourcePermissionTable" title='资源权限组列表'>
    <template slot="rowActions">
        <action name="authGroupResourcePermissionLookup"/>
        <action name="deleteOne" invisible="!activeRecord.isAllowDelete" confirm="删除权限组将清空关联角色的对应权限，确认删除吗？"/>
        <action name="active"/>
        <action name="disable"/>
    </template>
    <template slot="search">
        <field data="displayName" label="名称"/>
        <field data="type" label="权限组类型">
            <options>
                <option name="MANAGEMENT"/>
                <option name="RUNTIME"/>
            </options>
        </field>
        <field data="dataSource" label="数据来源">
            <options>
                <option name="SYSTEM"/>
                <option name="CUSTOM"/>
            </options>
        </field>
        <field data="active" label="激活状态"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <field data="name" invisible="true"/>
        <field data="isAllowDelete" invisible="true"/>

        <field data="displayName" label="名称"/>
        <field data="comment" label="描述"/>
        <field data="type"/>
        <field data="dataSource"/>
        <field data="resourceDisplayName"/>
        <field data="resourceType"/>
        <field data="active" label="激活状态"/>
        <field data="createDate"/>
        <field data="writeDate"/>
    </template>
</view>
