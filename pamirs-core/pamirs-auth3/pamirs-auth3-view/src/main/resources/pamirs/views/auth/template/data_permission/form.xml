<view type="FORM" model="auth.AuthGroupDataPermissionProxy" name="AuthGroupDataPermissionForm" title='数据权限组表单'>
    <template slot="actions">
        <action name="$$internal_GotoListTableRouter" type="default"/>
        <action name="create" validateForm="true" goBack="true"/>
        <action name="update" validateForm="true" goBack="true"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <field data="name" invisible="true"/>
        <pack widget="group" title="基础信息">
            <field data="displayName" label="名称" required="true"/>
            <field data="comment" label="描述"/>
        </pack>
        <pack widget="tabs">
            <pack widget="tab" title="角色">
                <field data="roles" widget="Table" labelInvisible="true">
                    <view type="table">
                        <template slot="actions">
                            <action name="authGroupDataPermissionAddRole" label="添加"/>
                            <action name="$$internal_DeleteOne" label="删除"/>
                        </template>
                        <template slot="search">
                            <field data="name" label="名称"/>
                            <field data="description" label="描述"/>
                            <field data="active" label="是否激活"/>
                        </template>
                        <template slot="fields">
                            <field data="id" invisible="true"/>
                            <field data="name" label="名称"/>
                            <field data="description" label="描述"/>
                            <field data="active" label="是否激活"/>
                        </template>
                    </view>
                </field>
            </pack>
            <pack widget="tab" title="数据权限">
                <field data="rowPermissions" widget="Table" labelInvisible="true" submitType="ALL">
                    <view type="table">
                        <template slot="actions">
                            <!--<action name="authGroupDataPermissionAddPermission" label="从已有中添加"/>-->
                            <!--<action name="authGroupDataPermissionCreatePermission" label="创建"/>-->
                            <action name="authGroupDataPermissionAddPermission" label="添加"/>
                            <action name="$$internal_DeleteOne" label="删除"/>
                        </template>
                        <!--<template slot="rowActions">-->
                        <!--    <action name="authGroupDataPermissionEditPermission" label="编辑"/>-->
                        <!--</template>-->
                        <template slot="search">
                            <field data="displayName" label="名称"/>
                            <field data="modelDefinition" label="权限模型"/>
                            <field data="domainExp" label="过滤条件表达式"/>
                            <field data="domainExpDisplayName" label="过滤条件"/>
                        </template>
                        <template slot="fields">
                            <field data="id" invisible="true"/>
                            <field data="code" invisible="true"/>
                            <field data="model" invisible="true"/>
                            <field data="source" invisible="true"/>
                            <field data="active" invisible="true"/>
                            <field data="domainExpJson" invisible="true"/>

                            <field data="displayName" label="名称"/>
                            <field data="description" label="描述"/>
                            <field data="modelDefinition" label="权限模型"/>
                            <field data="domainExp" label="过滤条件表达式"/>
                            <field data="domainExpDisplayName" label="过滤条件"/>
                            <field data="permRead" label="读权限" editable="true"/>
                            <!--<field data="permWrite" label="写权限" editable="true"/>-->
                            <!--<field data="permDelete" label="删除权限" editable="true"/>-->
                        </template>
                    </view>
                </field>
            </pack>
        </pack>
    </template>
</view>
