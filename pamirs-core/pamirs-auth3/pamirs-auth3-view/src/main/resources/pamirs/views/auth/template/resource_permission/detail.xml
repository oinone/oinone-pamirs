<view type="DETAIL" model="auth.AuthGroupResourcePermissionProxy" name="AuthGroupResourcePermissionDetail" title='资源权限组详情'>
    <template slot="actions">
        <action name="$$internal_GotoListTableRouter" type="default"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <pack widget="group" title="基础信息">
            <field data="displayName" label="名称" required="true"/>
            <field data="comment" label="描述"/>
        </pack>
        <pack widget="tabs">
            <pack widget="tab" title="角色">
                <field data="roles" widget="Table" labelInvisible="true">
                    <view type="table">
                        <template slot="fields">
                            <field data="id" invisible="true"/>
                            <field data="name" label="名称"/>
                            <field data="description" label="描述"/>
                            <field data="active" label="是否激活"/>
                        </template>
                    </view>
                </field>
            </pack>
            <pack widget="tab" title="资源管理权限">
                <field data="managementResourcePermissions" widget="Table" labelInvisible="true">
                    <view type="table">
                        <template slot="search">
                            <field data="module"/>
                            <field data="type"/>
                            <field data="subtype"/>
                        </template>
                        <template slot="fields">
                            <field data="id" invisible="true"/>

                            <field data="module"/>
                            <field data="type"/>
                            <field data="subtype"/>
                            <field data="displayName"/>
                            <field data="model"/>
                            <field data="name"/>
                            <field data="path"/>
                            <field data="source"/>
                            <field data="active"/>
                        </template>
                    </view>
                </field>
            </pack>
            <pack widget="tab" title="资源访问权限">
                <field data="accessResourcePermissions" widget="Table" labelInvisible="true">
                    <view type="table">
                        <template slot="search">
                            <field data="module"/>
                            <field data="type"/>
                            <field data="subtype"/>
                        </template>
                        <template slot="fields">
                            <field data="id" invisible="true"/>

                            <field data="module"/>
                            <field data="type"/>
                            <field data="subtype"/>
                            <field data="displayName"/>
                            <field data="model"/>
                            <field data="name"/>
                            <field data="path"/>
                            <field data="source"/>
                            <field data="active"/>
                        </template>
                    </view>
                </field>
            </pack>
        </pack>
    </template>
</view>
