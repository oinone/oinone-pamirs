<view type="TABLE" model="auth.AuthRowPermissionItem" name="AuthRowPermissionItemTable" title='数据权限项列表'>
    <template slot="actions">
        <action name="redirectCreatePage" label="创建"/>
        <action name="delete" label="删除" disabled="activeRecord.source == 'SYSTEM'" confirm="删除将导致所有相关角色的权限失效，确定要删除吗？"/>
    </template>
    <template slot="rowActions">
        <action name="redirectUpdatePage" label="编辑"/>
        <action name="redirectDetailPage" label="详情"/>
        <action name="delete" label="删除" invisible="activeRecord.source == 'SYSTEM'" confirm="删除将导致所有相关角色的权限失效，确定要删除吗？"/>
    </template>
    <template slot="search">
        <field data="displayName" label="名称"/>
        <field data="modelDefinition" label="权限模型"/>
        <field data="domainExp" label="过滤条件表达式"/>
        <field data="domainExpDisplayName" label="过滤条件"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <field data="code" invisible="true"/>
        <field data="model" invisible="true"/>
        <field data="source" invisible="true"/>

        <field data="displayName" label="名称"/>
        <field data="description" label="描述"/>
        <field data="modelDefinition" label="权限模型"/>
        <field data="domainExp" label="过滤条件表达式"/>
        <field data="domainExpDisplayName" label="过滤条件"/>
        <field data="createDate"/>
        <field data="writeDate"/>
    </template>
</view>
