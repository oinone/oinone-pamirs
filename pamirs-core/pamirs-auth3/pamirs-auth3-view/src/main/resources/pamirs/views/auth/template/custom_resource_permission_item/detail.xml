<view type="DETAIL" model="auth.AuthCustomResourcePermissionItem" name="AuthCustomResourcePermissionItemDetail" title="自定义资源权限项详情">
    <template slot="actions">
        <action name="$$internal_GotoListTableRouter" type="default"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <field data="model" invisible="true"/>
        <pack widget="group" title="权限项信息" cols="2">
            <field data="code" hint="未填时将自动生成" label="资源编码" readonly="activeRecord.id"/>
            <field data="type" label="资源类型"/>
            <field data="subtype" label="资源子类型"/>
            <field data="module" label="资源模块"/>
            <field data="modelDefinition" label="资源模型"/>
            <field data="name" label="资源名称"/>
            <field data="path" label="资源路径"/>
        </pack>
        <pack widget="group" title="其他信息" cols="2">
            <field data="createUserName" label="创建人" span="1"/>
            <field data="createDate" label="创建时间" span="1"/>
            <field data="writeUserName" label="更新人" span="1"/>
            <field data="writeDate" label="更新时间" span="1"/>
        </pack>
    </template>
</view>