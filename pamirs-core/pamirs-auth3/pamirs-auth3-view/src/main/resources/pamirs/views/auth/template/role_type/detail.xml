<view type="DETAIL" model="auth.AuthRoleType" name="AuthRoleTypeDetail" title="角色类型详情">
    <template slot="actions">
        <action name="$$internal_GotoListTableRouter" type="default"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <pack widget="group" title="基础信息" cols="2">
            <field data="code" label="角色类型编码" readonly="activeRecord.id" hint="未填时将自动生成"/>
            <field data="name" label="角色类型名称" required="true"/>
            <field data="description" label="角色类型描述" span="2"/>
        </pack>
        <pack widget="group" title="其他信息" cols="2">
            <field data="createUserName" label="创建人"/>
            <field data="createDate" label="创建时间"/>
            <field data="writeUserName" label="更新人"/>
            <field data="writeDate" label="更新时间"/>
        </pack>
    </template>
</view>