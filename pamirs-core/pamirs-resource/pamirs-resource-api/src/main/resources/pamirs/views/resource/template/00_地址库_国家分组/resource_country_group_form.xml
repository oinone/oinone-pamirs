<view widget="form" model="resource.ResourceCountryGroup" type="FORM" name="ResourceCountryGroupForm" title="国家分组">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
        <action name="create" invisible="activeRecord.id &gt; 0" model="resource.ResourceCountryGroup" goBack="true" validateForm="true" tag="contextFreeAction"/>
        <action name="update" invisible="!(activeRecord.id &gt; 0)" model="resource.ResourceCountryGroup" goBack="true" validateForm="true" tag="contextFreeAction"/>
    </template>
    <template slot="fields">
        <pack widget="group" title="基础信息" cols="2">
            <field name="id" invisible="true" model="resource.ResourceCountryGroup" data="id"/>
            <field span="1" name="code" widget="Input" model="resource.ResourceCountryGroup" data="code" label="编码" required="true" readonly="context.activeRecord.id" pattern="/^(?!\s|-|_)[\dA-Za-z_-]{1,30}$/"/>
            <field span="1" name="name" widget="Input" model="resource.ResourceCountryGroup" data="name" label="名称" required="true" readonly="context.activeRecord.code == &apos;Asia&apos; || context.activeRecord.code == &apos;Europe&apos; || context.activeRecord.code == &apos;Americas&apos; || context.activeRecord.code == &apos;Africa&apos; || context.activeRecord.code == &apos;Oceania&apos;"/>
        </pack>
        <pack widget="group" title="国家列表">
            <field name="countryList" widget="Table" model="resource.ResourceCountryGroup" data="countryList"
                   label="false">
                <view widget="table" model="resource.ResourceCountry">
                    <template slot="actions">
                        <action name="internalGotoM2MListDialogFromResourceCountryGroupFromResource" label="添加">
                            <view type="table">
                                <template slot="table">
                                    <field data="id" invisible="true"/>
                                    <field data="name" label="国家/地区名称"/>
                                    <field data="code" label="国家/地区编码"/>
                                    <field data="phoneCode" label="长途区号"/>
                                    <field data="countryGroup" label="所在洲"/>
                                </template>
                            </view>
                        </action>
                        <action fun="$$internal_DeleteOne" label="删除"/>
                    </template>
                    <template slot="fields">
                        <field data="id" invisible="true"/>
                        <field data="name" label="国家/地区名称"/>
                        <field data="code" label="国家/地区编码"/>
                        <field data="phoneCode" label="长途区号"/>
                        <field data="countryGroup" label="所在洲"/>
                    </template>
                </view>
            </field>
        </pack>
    </template>
</view>