<view name="语言detail" title="语言详情" type="DETAIL" cols="2" model="resource.ResourceLang">    <template slot="actions" autoFill="true"/>    <template slot="fields">        <pack widget="group" title="基础信息">            <field span="1" invisible="true" priority="5" data="id" label="ID" readonly="true"/>            <field span="1" priority="90" data="code" label="编码"/>            <field span="1" priority="101" data="name" label="语言名称"/>            <field span="1" priority="102" data="isoCode" label="语言ISO代码"/>            <field span="1" priority="103" data="resourceIcon" label="国旗" widget="LanguageBadge" optionFields="displayName,fullFontClass"/>            <field span="1" priority="104" data="direction" label="书写习惯"/>            <field span="1" priority="105" data="weekStart" label="一周开始日"/>            <field span="1" priority="110" data="calendarType" label="日历"/>            <field span="1" priority="111" data="timezoneType" label="时区"/>            <field span="1" priority="111" data="addressTypes" label="地址格式"/>            <field span="1" priority="111" data="addressFormat" invisible="true" label="地址格式"/>            <field span="1" priority="114" data="groupingRule" label="数字分组规则" defaultValue="3"/>            <field span="1" priority="107" data="decimalPoint" label="小数分隔符"/>            <field span="1" priority="108" data="thousandsSep" label="整数分隔符"/>            <field span="1" priority="109" data="active" label="激活状态"/>            <field span="1" priority="115" data="userCurrentLang" required="true" label="当前用户语言"/>        </pack>        <pack colSpan="FULL" cols="24" title="选项页" widget="containers">            <pack widget="row">                <pack widget="container">                    <pack colSpan="FULL" cols="24" layout="HORIZONTAL" title="日期格式" widget="group" help="注意：在选择完年、月、日后，请在元素之间手动输入分隔符（如‘-’、‘/’等）以完成日期格式。">                        <field required="true" data="resourceDateFormat" label="日期格式" widget="Form" labelInvisible="true">                            <view model="resource.ResourceDateFormat" type="form">                                <template slot="form">                                    <field required="true" invisible="true" data="hyphen" label="年-月-日"/>                                    <field required="true" invisible="true" data="slash" label="年/月/日"/>                                    <field required="true" invisible="true" data="chinese" label="年月日"/>                                    <field required="true" invisible="true" data="hyphenYearMonth" label="年-月"/>                                    <field required="true" invisible="true" data="slashYearMonth" label="年/月"/>                                    <field required="true" invisible="true" data="chineseYearMonth" label="年月"/>                                    <field required="true" optionalFields="Y,M,D" relationField="hyphen" widget="HyphenMapWidget" data="hyphenMap" label="年-月-日"/>                                    <field required="true" optionalFields="Y,M,D" relationField="slash" widget="SlashMapWidget" data="slashMap" label="年/月/日"/>                                    <field required="true" optionalFields="Y,M,D" relationField="chinese" widget="ChineseMapWidget" data="chineseMap" label="年月日"/>                                    <field required="true" optionalFields="Y,M" relationField="hyphenYearMonth" widget="HyphenYearMonthMapWidget" data="hyphenYearMonthMap" label="年-月"/>                                    <field required="true" optionalFields="Y,M" relationField="slashYearMonth" widget="SlashYearMonthMapWidget" data="slashYearMonthMap" label="年/月"/>                                    <field required="true" optionalFields="Y,M" relationField="chineseYearMonth" widget="ChineseYearMonthMapWidget" data="chineseYearMonthMap" label="年月"/>                                </template>                            </view>                        </field>                    </pack>                </pack>                <pack cols="24" title="容器" widget="container" widthType="FULL">                    <pack colSpan="FULL" cols="24" layout="HORIZONTAL" title="时间格式" help="注意：在选择完小时、分钟、秒后，请在元素之间手动输入分隔符（如‘:’）以完成时间格式。" widget="group">                        <field required="true" data="resourceTimeFormat" label="时间格式" widget="Form"                               labelInvisible="true">                            <view model="resource.ResourceTimeFormat" type="form">                                <template slot="form">                                    <field required="true" invisible="true" data="apColonNormal" label="上午/下午 时分秒"/>                                    <field required="true" invisible="true" data="apColonNormalSss" label="上午/下午 时分秒毫秒"/>                                    <field required="true" invisible="true" data="colonNormal" label="时分秒"/>                                    <field required="true" invisible="true" data="colonNormalSss" label="时分秒毫秒"/>                                    <field required="true" invisible="true" data="apColonShort" label="上午/下午 时分"/>                                    <field required="true" invisible="true" data="colonShort" label="时分"/>                                    <field required="true" optionalFields="A,H,M,S" relationField="apColonNormal" widget="ApColonNormalMapWidget" data="apColonNormalMap" label="上午/下午 时:分:秒"/>                                    <field required="true" optionalFields="A,H,M,S,Ms" relationField="apColonNormalSss" widget="ApColonNormalMapWidget" data="apColonNormalMap" label="上午/下午 时:分:秒.毫秒"/>                                    <field required="true" optionalFields="H,M,S" relationField="colonNormal" widget="ColonNormalMapWidget" data="colonNormalMap" label="时:分:秒"/>                                    <field required="true" optionalFields="H,M,S,Ms" relationField="colonNormalSss" widget="ColonNormalMapWidget" data="colonNormalMap" label="时:分:秒.毫秒"/>                                    <field required="true" optionalFields="A,H,M" relationField="apColonShort" widget="ApColonShortMapWidget" data="apColonShortMap" label="上午/下午 时:分"/>                                    <field required="true" optionalFields="H,M" relationField="colonShort" widget="ColonShortMapWidget" data="colonShortMap" label="时:分"/>                                </template>                            </view>                        </field>                    </pack>                </pack>            </pack>        </pack>        <field span="1" priority="106" data="installState" invisible="true" label="语言包安装状态"/>        <field span="1" priority="103" data="icon" invisible="true" label="图标"/>        <field span="1" priority="112" data="dateFormat" invisible="true" label="日期格式"/>        <field span="1" priority="113" data="timeFormat" invisible="true" label="时间格式"/>        <field span="1" invisible="true" priority="200" data="createDate" label="创建时间" readonly="true"/>        <field span="1" invisible="true" priority="210" data="writeDate" label="更新时间" readonly="true"/>        <field span="1" priority="220" data="createUid" label="创建人ID"/>        <field span="1" priority="230" data="writeUid" label="更新人ID"/>    </template></view>