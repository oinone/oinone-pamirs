<view widget="table" type="TABLE" title="地区" name="ResourceRegionProxyModelTable" model="resource.ResourceRegionProxyModel">
    <template slot="actions">
        <action name="synchronization" label="高德地址同步" refreshData="true" widget="ServerAction"/>
    </template>
    <template slot="fields">
        <field data="id" invisible="true"/>
        <field data="country" widget="Select" label="国家"/>
        <field data="province" widget="Select" label="省/州"/>
        <field data="city" widget="Select" label="市"/>
        <field data="district" widget="Select" label="区"/>
        <field data="street" widget="Select" label="街道"/>
    </template>
</view>