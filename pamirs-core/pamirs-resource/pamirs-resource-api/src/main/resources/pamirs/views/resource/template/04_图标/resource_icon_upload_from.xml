<view name="iconUploadManagement" type="GALLERY" model="resource.ResourceIcon">
    <template slot="actions">
        <action label="上传图标" name="uploads" model="resource.ResourceIconUpload"/>
    </template>
    <template slot="gallery" widget="iconUploadGallery" showIconManage="true" emptyText="无匹配条件图标"
              defaultPageSize="36" pageSizeOptions='10,15,30,36,50,100,200'>
        <template slot="rowActions">
            <element widget="iconActionBar" inline="true">
                <action name="iconEditAction" label="编辑"/>
                <action name="deleteOne" label="删除" confirm="确定要删除图标吗？"/>
                <action name="active" label="显示" invisible="activeRecord.show == true" widget="iconVisibilityAction"/>
                <action name="disabled" label="隐藏" invisible="activeRecord.show == false" widget="iconVisibilityAction"/>
            </element>
        </template>
        <template slot="field">
            <field name="id" data="id" label="id" invisible="true"/>
            <field name="outId" data="outId" label="图标id" invisible="true"/>
            <field name="type" data="type" label="图标类型" invisible="true"/>
            <field name="name" data="name" label="图标名称" invisible="true"/>
            <field name="displayName" data="displayName" label="图标显示名称"/>
            <field name="libId" data="libId" label="图标库id" invisible="true"/>
            <field name="lib" data="lib" label="图标库" invisible="true"/>
            <field name="groupId" data="groupId" label="分组id" invisible="true"/>
            <field name="group" data="group" label="分组"/>
            <field name="show" data="show" label="显隐"/>
            <field name="unicode" data="unicode" label="unicode" invisible="true"/>
            <field name="remark" data="remark" label="备注" invisible="true"/>
            <field name="fontClass" data="fontClass" label="字体图标类名" invisible="true"/>
            <field name="fullFontClass" data="fullFontClass" label="字体图标全类名" invisible="true"/>
            <field name="sys" data="sys" label="是否系统图标"/>
        </template>
    </template>
</view>
