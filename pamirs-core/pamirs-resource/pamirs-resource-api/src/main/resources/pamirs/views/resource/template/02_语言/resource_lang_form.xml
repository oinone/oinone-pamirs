<view name="语言form" type="FORM" cols="2" title="编辑语言" model="resource.ResourceLang">    <template slot="actions">        <action name="internalGotoListTableRouter" label="返回" fun="$$internal_GotoListTableRouter"/>        <action name="create" label="创建" validateForm="true" goBack="true"/>        <action name="update" label="更新" validateForm="true" goBack="true"/>    </template>    <template slot="fields">        <pack widget="group" title="基础信息">            <field data="id" label="ID" span="1" invisible="true" readonly="true"/>            <field data="code" label="编码" span="1"/>            <field data="name" label="语言名称" span="1"/>            <field data="isoCode" label="语言ISO代码" span="1"/>            <field data="resourceIcon" label="国旗" widget="LanguageBadge" span="1" optionFields="displayName,fullFontClass"/>            <field data="direction" label="书写习惯" span="1"/>            <field data="weekStart" label="一周开始日" span="1"/>            <field data="calendarType" label="日历" span="1"/>            <field data="timezoneType" label="时区" span="1"/>            <field data="addressTypes" label="地址格式" span="1"/>            <field data="addressFormat" label="地址格式" span="1" invisible="true"/>            <field data="groupingRule" label="数字分组规则" span="1" defaultValue="3"/>            <field data="decimalPoint" label="小数分隔符" span="1"/>            <field data="thousandsSep" label="整数分隔符" span="1"/>            <field data="active" label="激活状态" span="1" defaultValue="ACTIVE"/>            <field data="userCurrentLang" label="当前用户语言" span="1" required="true"/>        </pack>        <pack colSpan="FULL" cols="24" title="选项页" widget="containers">            <pack widget="row">                <pack widget="container">                    <pack colSpan="FULL" cols="24" layout="HORIZONTAL" title="日期格式" widget="group" help="注意：在选择完年、月、日后，请在元素之间手动输入分隔符（如‘-’、‘/’等）以完成日期格式。">                        <field required="true" data="resourceDateFormat" label="日期格式" widget="Form" labelInvisible="true">                            <view model="resource.ResourceDateFormat" type="form">                                <template slot="form">                                    <field data="hyphen" label="年-月-日" invisible="true"/>                                    <field data="slash" label="年/月/日" invisible="true"/>                                    <field data="chinese" label="年月日" invisible="true"/>                                    <field data="hyphenYearMonth" label="年-月" invisible="true"/>                                    <field data="slashYearMonth" label="年/月" invisible="true"/>                                    <field data="chineseYearMonth" label="年月" invisible="true"/>                                    <field data="hyphenMap" label="年-月-日" widget="HyphenMapWidget" required="true" optionalFields="Y,M,D" relationField="hyphen"/>                                    <field data="slashMap" label="年/月/日" widget="SlashMapWidget" required="true" optionalFields="Y,M,D" relationField="slash"/>                                    <field data="chineseMap" label="年月日" widget="ChineseMapWidget" required="true" optionalFields="Y,M,D" relationField="chinese"/>                                    <field data="hyphenYearMonthMap" label="年-月" widget="HyphenYearMonthMapWidget" required="true" optionalFields="Y,M" relationField="hyphenYearMonth"/>                                    <field data="slashYearMonthMap" label="年/月" widget="SlashYearMonthMapWidget" required="true" optionalFields="Y,M" relationField="slashYearMonth"/>                                    <field data="chineseYearMonthMap" label="年月" widget="ChineseYearMonthMapWidget" required="true" optionalFields="Y,M" relationField="chineseYearMonth"/>                                </template>                            </view>                        </field>                    </pack>                </pack>                <pack cols="24" title="容器" widget="container" widthType="FULL">                    <pack colSpan="FULL" cols="24" layout="HORIZONTAL" title="时间格式" help="注意：在选择完小时、分钟、秒后，请在元素之间手动输入分隔符（如‘:’）以完成时间格式。" widget="group">                        <field required="true" data="resourceTimeFormat" label="时间格式" widget="Form" labelInvisible="true">                            <view model="resource.ResourceTimeFormat" type="form">                                <template slot="form">                                    <field data="apColonNormal" label="上午/下午 时:分:秒" required="true" invisible="true"/>                                    <field data="apColonNormalSss" label="上午/下午 时:分:秒.毫秒" required="true" invisible="true"/>                                    <field data="colonNormal" label="时:分:秒" required="true" invisible="true"/>                                    <field data="colonNormalSss" label="时:分:秒.毫秒" required="true" invisible="true"/>                                    <field data="apColonShort" label="上午/下午 时:分" required="true" invisible="true"/>                                    <field data="colonShort" label="时:分" required="true" invisible="true"/>                                    <field data="apColonNormalMap" label="上午/下午 时:分:秒" required="true" optionalFields="A,H,M,S" relationField="apColonNormal" widget="ApColonNormalMapWidget"/>                                    <field data="apColonNormalSssMap" label="上午/下午 时:分:秒.毫秒" required="true" optionalFields="A,H,M,S,Ms" relationField="apColonNormal" widget="ApColonNormalMapWidget"/>                                    <field data="colonNormalMap" label="时:分:秒" required="true" optionalFields="H,M,S" relationField="colonNormal" widget="ColonNormalMapWidget"/>                                    <field data="colonNormalSssMap" label="时:分:秒.毫秒" required="true" optionalFields="H,M,S,Ms" relationField="colonNormal" widget="ColonNormalMapWidget"/>                                    <field data="apColonShortMap" label="上午/下午 时:分" required="true" optionalFields="A,H,M" relationField="apColonShort" widget="ApColonShortMapWidget"/>                                    <field data="colonShortMap" label="时:分" required="true" optionalFields="H,M" relationField="colonShort" widget="ColonShortMapWidget"/>                                </template>                            </view>                        </field>                    </pack>                </pack>            </pack>        </pack>        <field data="installState" label="语言包安装状态" span="1" invisible="true"/>        <field data="icon" label="图标" span="1" invisible="true"/>        <field data="dateFormat" label="日期格式" span="1" invisible="true"/>        <field data="timeFormat" label="时间格式" span="1" invisible="true"/>        <field data="createDate" label="创建时间" span="1" invisible="true" readonly="true"/>        <field data="writeDate" label="更新时间" span="1" invisible="true" readonly="true"/>        <field data="createUid" label="创建人ID" span="1"/>        <field data="writeUid" label="更新人ID" span="1"/>    </template></view>