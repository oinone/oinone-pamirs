<view widget="form" name="货币form" title="货币" model="resource.ResourceCurrency" type="FORM">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter"
                type="default"/>
        <action name="create" invisible="activeRecord.id &gt; 0" model="resource.ResourceCurrency" goBack="true"
                validateForm="true" tag="contextFreeAction"/>
        <action name="update" invisible="!(activeRecord.id &gt; 0)" model="resource.ResourceCurrency" goBack="true"
                validateForm="true" tag="contextFreeAction"/>

    </template>
    <template slot="fields">
        <pack widget="group" title="基础信息" cols="2">
            <field name="id" invisible="true" model="resource.ResourceCurrency" data="id" required="false"/>
            <field name="active" invisible="true" model="resource.ResourceCurrency" data="active" required="false" value="true"/>
            <field span="1" name="code" widget="Input" model="resource.ResourceCurrency" data="code" label="编码"
                   readonly="context.activeRecord.id" pattern="/^(?!\s|-|_)[\dA-Za-z_-]{1,30}$/"/>
            <field span="1" name="name" widget="Input" model="resource.ResourceCurrency" data="name" label="名称"
                   pattern="/^(?!\s|-|_|\(|\))[\u4e00-\u9fa5\dA-Za-z-_\s]{1,50}$/"/>
            <field span="1" name="symbol" widget="Input" model="resource.ResourceCurrency" data="symbol" label="货币符号"/>
            <field span="1" name="position" widget="Select" model="resource.ResourceCurrency" data="position"
                   label="符号位置"/>
            <field span="1" name="rounding" widget="Select" model="resource.ResourceCurrency" data="rounding"
                   label="精确方式"/>
            <field span="1" name="decimalPlaces" widget="Integer" model="resource.ResourceCurrency" data="decimalPlaces"
                   label="小数精度"/>
            <field span="1" name="currencyUnitLabel" widget="Input" model="resource.ResourceCurrency"
                   data="currencyUnitLabel" label="整数单位"/>
            <field span="1" name="currencySubunitLabel" widget="Input" model="resource.ResourceCurrency"
                   data="currencySubunitLabel" label="小数单位"/>
        </pack>
        <pack widget="group" title="外部编码关联" cols="1">
            <field name="outResourceRelationList" widget="Table" model="resource.ResourceCurrency" data="outResourceRelationList" label="false">
                <view widget="table" model="resource.OutResourceRelation" showInlineActions="false" excluded-actions="redirectUpdatePage,redirectCreatePage">
                    <template slot="actionBar" widget="actionBar">
                        <action allowClear="true" cancelText="取消" confirm="确认要执行动作吗？" confirmPosition="BM"
                                confirmType="POPPER" disabled="false" enableConfirm="false" enterText="确定"
                                invisible="false" label="创建" model="resource.OutResourceRelation"
                                name="currencyCreateOutResourceRelation" readonly="false" required="false"
                                type="PRIMARY" widget="ViewAction">
                            <template slot="default" widget="modal">
                                <view model="resource.OutResourceRelation" type="form">
                                    <template slot="form" widget="form">
                                        <field data="id" invisible="true"/>
                                        <field name="sourceType" widget="Input" model="resource.OutResourceRelation" data="sourceType" label="来源类型" independently-editable="true"/>
                                        <field name="outCode" widget="Input" model="resource.OutResourceRelation" data="outCode" label="外部编码" independently-editable="true"/>
                                        <field name="extra" widget="Text" model="resource.OutResourceRelation" data="extra" label="拓展字段" independently-editable="true"/>
                                        <field name="relationCode" invisible="true" model="resource.OutResourceRelation" data="relationCode"/>
                                    </template>
                                </view>
                            </template>
                        </action>
                        <action name="$$internal_DeleteOne" label="删除" actionType="CLIENT"
                                model="business.PamirsDepartment" contextType="SINGLE_AND_BATCH"
                                fun="$$internal_DeleteOne" tag="contextFreeAction"/>
                    </template>
                    <template slot="fields">
                        <field name="id" invisible="true" model="resource.OutResourceRelation" data="id"/>
                        <field name="sourceType" widget="Input" model="resource.OutResourceRelation" data="sourceType"
                               label="来源类型" independently-editable="true"/>
                        <field name="outCode" widget="Input" model="resource.OutResourceRelation" data="outCode"
                               label="外部编码" independently-editable="true"/>
                        <field name="extra" widget="Text" model="resource.OutResourceRelation" data="extra" label="拓展字段"
                               independently-editable="true"/>
                        <field name="relationCode" invisible="true" model="resource.OutResourceRelation"
                               data="relationCode"/>
                        <field name="model" invisible="true" model="resource.OutResourceRelation" data="model"/>
                    </template>
                </view>
            </field>
        </pack>
    </template>
</view>