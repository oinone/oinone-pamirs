<view widget="detail" type="DETAIL" model="resource.ResourceStreet" name="街道detail" title="街道" submit="all">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter"
                type="default"/>
    </template>
    <template slot="fields">
        <pack widget="group" title="基础信息" cols="2">
            <field name="id" invisible="true" model="resource.ResourceStreet" data="id"/>
            <field name="sourceType" invisible="true" model="resource.ResourceStreet" data="sourceType"/>
            <field span="1" name="code" widget="Input" model="resource.ResourceStreet" data="code" label="街道代码"
                   required="true" readonly="context.activeRecord.id" pattern="/^(?!\s|-|_)[\dA-Za-z_-]{1,30}$/"/>
            <field span="1" name="name" widget="Input" model="resource.ResourceStreet" data="name" label="街道名称"
                   required="true"/>
            <field span="1" name="country" widget="Select" model="resource.ResourceStreet" data="country" label="国家/地区"
                   required="true"/>
            <field span="1" name="province" widget="Select" model="resource.ResourceStreet" data="province" label="省/州"
                   required="true"/>
            <field span="1" name="city" widget="Select" model="resource.ResourceStreet" data="city" label="市"
                   required="true"/>
            <field span="1" name="district" widget="Select" model="resource.ResourceStreet" data="district" label="区/县"
                   required="true"/>
        </pack>
        <pack widget="tabs">
            <pack widget="group" title="外部编码" cols="1">
                <field name="outResourceRelationList" widget="Table" model="resource.ResourceStreet"
                       data="outResourceRelationList" label="false">
                    <view widget="table" model="resource.OutResourceRelation" showInlineActions="false"
                          excluded-actions="$$internal_GotoO2MEditDialog,redirectUpdatePage,redirectCreatePage">
                        <template slot="fields">
                            <field name="id" invisible="true" model="resource.OutResourceRelation" data="id"/>
                            <field name="sourceType" widget="Input" model="resource.OutResourceRelation"
                                   data="sourceType" label="来源类型"/>
                            <field name="outCode" widget="Input" model="resource.OutResourceRelation" data="outCode"
                                   label="外部编码"/>
                            <field name="extra" widget="Text" model="resource.OutResourceRelation" data="extra"
                                   label="拓展字段"/>
                            <field name="relationCode" invisible="true" model="resource.OutResourceRelation"
                                   data="relationCode"/>
                            <field name="model" invisible="true" model="resource.OutResourceRelation" data="model"/>
                        </template>
                    </view>
                </field>
            </pack>
        </pack>
    </template>
</view>