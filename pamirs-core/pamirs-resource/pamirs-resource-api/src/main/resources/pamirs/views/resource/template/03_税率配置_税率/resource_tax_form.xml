<view widget="form" model="resource.ResourceTax" name="ResourceTaxForm" title="税率" type="FORM" priority="10">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter" type="default"/>
        <action name="create" invisible="activeRecord.id &gt; 0" model="resource.ResourceTax" goBack="true" validateForm="true" tag="contextFreeAction"/>
        <action name="update" invisible="!(activeRecord.id &gt; 0)" model="resource.ResourceTax" goBack="true" validateForm="true" tag="contextFreeAction"/>
    </template>
    <template slot="fields">
        <pack widget="group" title="基础信息" cols="2">
            <field name="id" invisible="true" model="resource.ResourceTax" data="id"/>
            <field name="code" widget="Input" model="resource.ResourceTax" data="code" label="税率编码"/>
            <field name="name" widget="Input" model="resource.ResourceTax" data="name" label="税率名称"/>
            <field name="tax" widget="Float" model="resource.ResourceTax" data="tax" label="税率"/>
            <field name="taxKind" widget="Select" model="resource.ResourceTax" data="taxKind" label="税种"/>
        </pack>
        <pack widget="tabs">

            <pack widget="group" title="外部编码" cols="1">
                <field name="outResourceRelationList" widget="Table" model="resource.ResourceTax" data="outResourceRelationList" label="false">
                    <view widget="table" model="resource.OutResourceRelation" showInlineActions="false"
                          excluded-actions="redirectUpdatePage,redirectCreatePage">
                        <template slot="actionBar" widget="actionBar">
                            <action allowClear="true" cancelText="取消" confirm="确认要执行动作吗？" confirmPosition="BM" confirmType="POPPER" disabled="false" enableConfirm="false" enterText="确定" invisible="false" label="创建" model="resource.OutResourceRelation" name="taxCreateOutResourceRelation" readonly="false" required="false" type="PRIMARY" widget="ViewAction">
                                <template slot="default" widget="modal">
                                    <view model="resource.OutResourceRelation" type="form">
                                        <template slot="form" widget="form">
                                            <field data="id" invisible="true"/>
                                            <field name="sourceType" widget="Input" model="resource.OutResourceRelation" data="sourceType" label="来源类型" independently-editable="true"/>
                                            <field name="outCode" widget="Input" model="resource.OutResourceRelation" data="outCode" label="外部编码" independently-editable="true"/>
                                            <field name="extra" widget="Text" model="resource.OutResourceRelation" data="extra" label="拓展字段" independently-editable="true"/>
                                            <field name="relationCode" invisible="true" model="resource.OutResourceRelation" data="relationCode"/>
                                        </template>
                                    </view>
                                </template>
                            </action>
                            <action name="$$internal_DeleteOne" label="删除" actionType="CLIENT" model="resource.OutResourceRelation" contextType="SINGLE_AND_BATCH" fun="$$internal_DeleteOne" tag="contextFreeAction"/>
                        </template>
                        <template slot="fields">
                            <field name="id" invisible="true" model="resource.OutResourceRelation" data="id"/>
                            <field name="sourceType" widget="Input" model="resource.OutResourceRelation" data="sourceType" label="来源类型" independently-editable="true"/>
                            <field name="outCode" widget="Input" model="resource.OutResourceRelation" data="outCode" label="外部编码" independently-editable="true"/>
                            <field name="extra" widget="Text" model="resource.OutResourceRelation" data="extra" label="拓展字段" independently-editable="true"/>
                            <field name="relationCode" invisible="true" model="resource.OutResourceRelation" data="relationCode"/>
                        </template>
                    </view>
                </field>
            </pack>
        </pack>
    </template>
</view>