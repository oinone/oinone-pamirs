<view widget="form" type="FORM" model="resource.ResourceStreet" name="街道form" title="街道" submit="all" priority="10">
    <template slot="actions">
        <action name="internalGotoListTableRouter" label="返回" actionType="CLIENT" fun="$$internal_GotoListTableRouter"
                type="default"/>
        <action name="create" invisible="activeRecord.id &gt; 0" model="resource.ResourceStreet" goBack="true" validateForm="true" tag="contextFreeAction"/>
        <action name="update" invisible="!(activeRecord.id &gt; 0)" model="resource.ResourceStreet" goBack="true" validateForm="true" tag="contextFreeAction"/>
    </template>
    <template slot="fields">
        <pack widget="group" title="基础信息" cols="2">
            <field name="id" invisible="true" model="resource.ResourceStreet" data="id"/>
            <field name="sourceType" invisible="true" model="resource.ResourceStreet" data="sourceType"/>
            <field span="1" name="code" widget="Input" model="resource.ResourceStreet" data="code" label="街道代码"
                   required="true" readonly="context.activeRecord.id"/>
            <field span="1" name="name" widget="Input" model="resource.ResourceStreet" data="name" label="街道名称"
                   required="true" pattern="/^(?!\s|-|_|\(|\))[\u4e00-\u9fa5\dA-Za-z-_\s]{1,50}$/"/>
            <field span="1" name="country" widget="Select" model="resource.ResourceStreet" data="country" label="国家/地区"
                   required="true"/>
            <field span="1" name="province" widget="Select" model="resource.ResourceStreet" data="province" label="省/州"
                   required="true"/>
            <field span="1" name="city" widget="Select" model="resource.ResourceStreet" data="city" label="市"
                   required="true"/>
            <field span="1" name="district" widget="Select" model="resource.ResourceStreet" data="district" label="区/县"
                   required="true"/>
        </pack>
        <pack widget="tabs">
            <pack widget="group" title="外部编码" cols="1">
                <field name="outResourceRelationList" widget="Table" model="resource.ResourceStreet"
                       data="outResourceRelationList" label="false">
                    <view widget="table" model="resource.OutResourceRelation" showInlineActions="false"
                          excluded-actions="redirectUpdatePage,redirectCreatePage">
                        <template slot="actionBar" widget="actionBar">
                            <action allowClear="true" cancelText="取消" confirm="确认要执行动作吗？" confirmPosition="BM" confirmType="POPPER" disabled="false" enableConfirm="false" enterText="确定" invisible="false" label="创建" model="resource.OutResourceRelation" name="streetCreateOutResourceRelation" readonly="false" required="false" type="PRIMARY" widget="ViewAction">
                                <template slot="default" widget="modal">
                                    <view model="resource.OutResourceRelation" type="form">
                                        <template slot="form" widget="form">
                                            <field data="id" invisible="true"/>
                                            <field name="sourceType" widget="Input" model="resource.OutResourceRelation" data="sourceType" label="来源类型" independently-editable="true"/>
                                            <field name="outCode" widget="Input" model="resource.OutResourceRelation" data="outCode" label="外部编码" independently-editable="true"/>
                                            <field name="extra" widget="Text" model="resource.OutResourceRelation" data="extra" label="拓展字段" independently-editable="true"/>
                                            <field name="relationCode" invisible="true" model="resource.OutResourceRelation" data="relationCode"/>
                                        </template>
                                    </view>
                                </template>
                            </action>
                            <action name="$$internal_DeleteOne" label="删除" actionType="CLIENT" model="business.PamirsDepartment" contextType="SINGLE_AND_BATCH" fun="$$internal_DeleteOne" tag="contextFreeAction"/>
                        </template>
                        <template slot="fields">
                            <field name="id" invisible="true" model="resource.OutResourceRelation" data="id"/>
                            <field name="sourceType" widget="Input" model="resource.OutResourceRelation" data="sourceType" label="来源类型" independently-editable="true"/>
                            <field name="outCode" widget="Input" model="resource.OutResourceRelation" data="outCode" label="外部编码" independently-editable="true"/>
                            <field name="extra" widget="Text" model="resource.OutResourceRelation" data="extra" label="拓展字段" independently-editable="true"/>
                            <field name="relationCode" invisible="true" model="resource.OutResourceRelation" data="relationCode"/>
                            <field name="model" invisible="true" model="resource.OutResourceRelation" data="model"/>
                        </template>
                    </view>
                </field>
            </pack>
        </pack>
    </template>
</view>